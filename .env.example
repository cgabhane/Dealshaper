# CPS Deal Navigator — Environment Variables
  # Copy this file to .env and fill in your values

  # PostgreSQL database connection string
  # Examples:
  #   Local:    postgresql://postgres:password@localhost:5432/dealshaper
  #   Neon:     postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/dealshaper
  #   Railway:  postgresql://postgres:pass@containers-us-west-xxx.railway.app:PORT/railway
  DATABASE_URL=postgresql://user:password@host:5432/dealshaper

  # Secret key for session signing (use a long random string)
  SESSION_SECRET=change-me-to-a-long-random-secret-string
  